def read_img(path, size):
    img = cv2.imread(path, cv2.IMREAD_COLOR)
    if img is None: return None
    img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)
    img = cv2.resize(img, (size, size), interpolation=cv2.INTER_AREA)
    return img.astype(np.float32) / 255.0

def read_mask(path, size):
    if not os.path.exists(path):
        return np.zeros((size, size, 1), np.float32)
    m = cv2.imread(path, cv2.IMREAD_GRAYSCALE)
    if m is None: return np.zeros((size, size, 1), np.float32)
    m = cv2.resize(m, (size, size), interpolation=cv2.INTER_NEAREST)
    return (m > 127).astype(np.float32)[..., np.newaxis]

def cap_classes(imgs, masks, labels, max_n):
    keep = []
    for c in np.unique(labels):
        idx = np.where(labels == c)[0]
        idx = np.random.choice(idx, min(len(idx), max_n), replace=False)
        keep.extend(idx.tolist())
    keep = np.array(keep); np.random.shuffle(keep)
    return imgs[keep], masks[keep], labels[keep]

def augment_batch(imgs, masks):
    """Simple numpy augmentation: flip + brightness."""
    out_i, out_m = [], []
    for img, msk in zip(imgs, masks):
        if np.random.rand() > 0.5:
            img = img[:, ::-1, :]; msk = msk[:, ::-1, :]
        if np.random.rand() > 0.5:
            img = img[::-1, :, :]; msk = msk[::-1, :, :]
        delta = np.random.uniform(-0.1, 0.1)
        img = np.clip(img + delta, 0, 1)
        out_i.append(img); out_m.append(msk)
    return np.array(out_i, np.float32), np.array(out_m, np.float32)

def load_brain(path, size, max_n):
    print("\n  [Brain Tumor] Scanning:", path)
    img_paths = [p for p in glob.glob(os.path.join(path,'*','*.tif'))
                 if '_mask' not in os.path.basename(p)]
    if not img_paths:
        raise FileNotFoundError(f"Brain data not found at: {path}")
    print(f"    Found {len(img_paths)} files")
    imgs, masks, areas = [], [], []
    for ip in img_paths:
        mp  = ip.replace('.tif','_mask.tif')
        img = read_img(ip, size); msk = read_mask(mp, size)
        if img is None: continue
        imgs.append(img); masks.append(msk); areas.append(float(msk.sum()))
    imgs=np.array(imgs,np.float32); masks=np.array(masks,np.float32); areas=np.array(areas)
    labels=np.zeros(len(areas),np.int32)
    t=areas>0
    if t.sum()>0:
        q1,q2=np.percentile(areas[t],[33,66])
        labels[t&(areas<=q1)]=1; labels[t&(areas>q1)&(areas<=q2)]=2; labels[t&(areas>q2)]=3
    imgs,masks,labels=cap_classes(imgs,masks,labels,max_n)
    print(f"    ✓ {len(imgs)} images | sev: {np.bincount(labels,minlength=4).tolist()}")
    return imgs,masks,labels

def _atrophy_mask(sev, size):
    m=np.zeros((size,size),np.float32)
    if sev==0: return m[...,np.newaxis]
    cx,cy=size//2,size//2; r=int(size*(0.08+sev*0.06)); r2=max(2,r//2); off=size//5
    cv2.circle(m,(cx,cy),r,1.0,-1); cv2.circle(m,(cx-off,cy),r2,1.0,-1)
    cv2.circle(m,(cx+off,cy),r2,1.0,-1)
    return m[...,np.newaxis]

def load_alzheimer(path, size, max_n):
    print("\n  [Alzheimer's] Scanning:", path)
    cmap={'NonDemented':0,'VeryMildDemented':1,'MildDemented':2,'ModerateDemented':3}
    imgs,masks,labels=[],[],[]
    for cn,cid in cmap.items():
        cp=os.path.join(path,cn)
        if not os.path.isdir(cp): continue
        for fp in glob.glob(os.path.join(cp,'*.jpg'))+glob.glob(os.path.join(cp,'*.png')):
            img=read_img(fp,size)
            if img is None: continue
            imgs.append(img); masks.append(_atrophy_mask(cid,size)); labels.append(cid)
    if not imgs: raise FileNotFoundError(f"Alzheimer's data not found at: {path}")
    imgs=np.array(imgs,np.float32); masks=np.array(masks,np.float32); labels=np.array(labels,np.int32)
    imgs,masks,labels=cap_classes(imgs,masks,labels,max_n)
    print(f"    ✓ {len(imgs)} images | cls: {np.bincount(labels,minlength=4).tolist()}")
    return imgs,masks,labels

def load_busi(path, size, max_n):
    print("\n  [Breast Cancer] Scanning:", path)
    folders={'normal':0,'benign':1,'malignant':3}
    imgs,masks,labels=[],[],[]
    for fname,blbl in folders.items():
        fp=os.path.join(path,fname)
        if not os.path.isdir(fp): continue
        img_files=[f for f in glob.glob(os.path.join(fp,'*.png'))+glob.glob(os.path.join(fp,'*.jpg'))
                   if '_mask' not in os.path.basename(f)]
        for ipath in img_files:
            img=read_img(ipath,size)
            if img is None: continue
            base,ext=os.path.splitext(ipath)
            msk=read_mask(base+'_mask'+ext,size)
            lbl=2 if (fname=='benign' and msk.sum()/(size*size)>0.05) else blbl
            imgs.append(img); masks.append(msk); labels.append(lbl)
    if not imgs: raise FileNotFoundError(f"BUSI data not found at: {path}")
    imgs=np.array(imgs,np.float32); masks=np.array(masks,np.float32); labels=np.array(labels,np.int32)
    imgs,masks,labels=cap_classes(imgs,masks,labels,max_n)
    print(f"    ✓ {len(imgs)} images | sev: {np.bincount(labels,minlength=4).tolist()}")
    return imgs,masks,labels

def load_all(cfg):
    print("\n"+"="*65+"\n  STEP 1 — Loading Datasets\n"+"="*65)
    S,M=cfg['img_size'],cfg['max_per_class']
    Xi,Si,Yd,Ys=[],[],[],[]
    b,bs,bv=load_brain(cfg['brain_path'],S,M)
    Xi.append(b); Si.append(bs); Yd.append(np.zeros(len(b),np.int32)); Ys.append(bv)
    a,as_,av=load_alzheimer(cfg['alzheimer_path'],S,M)
    Xi.append(a); Si.append(as_); Yd.append(np.ones(len(a),np.int32)); Ys.append(av)
    r,rs,rv=load_busi(cfg['busi_path'],S,M)
    Xi.append(r); Si.append(rs); Yd.append(np.full(len(r),2,np.int32)); Ys.append(rv)
    X=np.concatenate(Xi,0).astype(np.float32)
    seg=np.concatenate(Si,0).astype(np.float32)
    yd=np.concatenate(Yd,0)
    ys=np.minimum(np.concatenate(Ys,0),3).astype(np.int32)
    idx=np.arange(len(X)); np.random.shuffle(idx)
    X,seg,yd,ys=X[idx],seg[idx],yd[idx],ys[idx]
    print(f"\n  Combined: {X.shape} | diseases={np.bincount(yd).tolist()} | "
          f"severity={np.bincount(ys,minlength=4).tolist()}")
    return X,seg,yd,ys

# =============================================================================
#  NOVEL C1 — QUANTUM-INSPIRED ENCODING LAYER
# =============================================================================
class QuantumEncodingLayer(Layer):
    def build(self, input_shape):
        self.phase=self.add_weight(name='phase',shape=(1,),initializer='zeros',trainable=True)
        self.scale=self.add_weight(name='scale',shape=(1,),initializer='ones', trainable=True)
        super().build(input_shape)
    def call(self, x):
        theta=ops.arctan(x*(np.pi/2.0)); phi=theta+self.phase
        q=ops.cos(theta)**2*ops.cos(phi)**2+ops.sin(theta)**2*ops.sin(phi)**2
        return ops.clip(x*self.scale+q, 0.0, 1.0)
    def get_config(self): return super().get_config()

# =============================================================================
#  NOVEL C2 — FUZZY MEMBERSHIP ACTIVATION (n_sets=3, stable)
# =============================================================================
class FuzzyMembershipActivation(Layer):
    def __init__(self, n_sets=3, **kw):
        super().__init__(**kw); self.n_sets=n_sets
    def build(self, input_shape):
        ch=input_shape[-1]
        self.centers=self.add_weight(
            name='centers',shape=(self.n_sets,),
            initializer=keras.initializers.Constant(np.linspace(0,1,self.n_sets).tolist()),
            trainable=True)
        self.widths=self.add_weight(
            name='widths',shape=(self.n_sets,),
            initializer=keras.initializers.Constant([0.4]*self.n_sets),
            constraint=keras.constraints.NonNeg(),trainable=True)
        self.rules=self.add_weight(
            name='rules',shape=(self.n_sets,ch),
            initializer='glorot_uniform',trainable=True)
        super().build(input_shape)
    def call(self, x):
        xn=ops.sigmoid(x); agg=ops.zeros_like(xn)
        for i in range(self.n_sets):
            w=ops.maximum(self.widths[i],1e-6)
            mu=ops.maximum(0.0,1.0-ops.abs(xn-self.centers[i])/w)
            agg=agg+mu*self.rules[i]
        return agg/self.n_sets+ops.relu(x)*0.5   # strong residual
    def get_config(self):
        c=super().get_config(); c['n_sets']=self.n_sets; return c

# =============================================================================
#  CBAM ATTENTION
# =============================================================================
class _CM(Layer):
    def call(self,x): return ops.mean(x,axis=-1,keepdims=True)
class _CX(Layer):
    def call(self,x): return ops.max(x,axis=-1,keepdims=True)

def cbam(x, ratio=8):
    ch=x.shape[-1]
    g=Reshape((1,1,ch))(GlobalAveragePooling2D()(x))
    g=Conv2D(max(1,ch//ratio),1,activation='relu',  use_bias=False)(g)
    g=Conv2D(ch,              1,activation='sigmoid',use_bias=False)(g)
    x=Multiply()([x,g])
    s=Concatenate()([_CM()(x),_CX()(x)])
    s=Conv2D(1,7,padding='same',activation='sigmoid',use_bias=False)(s)
    return Multiply()([x,s])

# =============================================================================
#  NOVEL C3 — ADAPTIVE MULTI-MODAL FUSION
# =============================================================================
class _WAdd(Layer):
    def call(self, inputs):
        w,f1,f2,f3=inputs
        w1=ops.reshape(w[:,0:1],(-1,1,1,1)); w2=ops.reshape(w[:,1:2],(-1,1,1,1)); w3=ops.reshape(w[:,2:3],(-1,1,1,1))
        return w1*f1+w2*f2+w3*f3

def modal_fusion(f1, f2, f3, filters, tag=''):
    g=Concatenate()([GlobalAveragePooling2D()(f1),GlobalAveragePooling2D()(f2),GlobalAveragePooling2D()(f3)])
    w=Dense(32,activation='relu',name=f'ff_{tag}')(g)
    w=Dense(3,activation='softmax',name=f'fw_{tag}')(w)
    o=_WAdd(name=f'mf_{tag}')([w,f1,f2,f3])
    o=Conv2D(filters,1,padding='same',name=f'fp_{tag}')(o)
    return BatchNormalization(name=f'fb_{tag}')(o)

# =============================================================================
#  QF-CNN v5 — KEY INSIGHT:
#  Use MobileNetV2 as pretrained backbone inside the encoder.
#  Wrap the pretrained features with C1 (quantum) BEFORE the backbone,
#  and C2 (fuzzy) AFTER each feature level.
#  This gives pretrained feature quality + novel contributions on top.
# =============================================================================
def build_qfcnn(cfg):
    S,CH=cfg['img_size'],cfg['channels']
    ND,ST=cfg['num_diseases'],cfg['stages']
    inp=Input((S,S,CH),name='input')

    # C1: Quantum encoding applied to input
    q_inp=QuantumEncodingLayer(name='quantum_enc')(inp)

    # Pretrained MobileNetV2 backbone (ImageNet weights)
    backbone=MobileNetV2(input_shape=(S,S,CH),include_top=False,weights='imagenet')
    backbone.trainable=False   # frozen in Phase 1, unfrozen in Phase 2

    # Extract multi-scale features from backbone
    feat_names=['block_1_expand_relu',   # S/2,  16ch
                'block_3_expand_relu',   # S/4,  24ch
                'block_6_expand_relu',   # S/8,  32ch
                'out_relu']              # S/32, 1280ch

    # Build sub-model extracting these features
    bb_model=Model(backbone.input,
                   [backbone.get_layer(n).output for n in feat_names],
                   name='backbone')

    # Apply backbone to quantum-encoded input
    f1,f2,f3,f4=bb_model(q_inp)

    # C2: Fuzzy activation applied after each feature level
    f1=FuzzyMembershipActivation(name='fma1')(f1)
    f2=FuzzyMembershipActivation(name='fma2')(f2)
    f3=FuzzyMembershipActivation(name='fma3')(f3)

    # C3: Multi-modal fusion at bottleneck level
    # Simulate CT/PET variants via 1×1 projection of bottleneck
    f4_ct =Conv2D(64,1,name='ct_proj')(f4)
    f4_pet=Conv2D(64,1,name='pet_proj')(f4)
    f4_mri=Conv2D(64,1,name='mri_proj')(f4)
    fused =modal_fusion(f4_mri,f4_ct,f4_pet,64,tag='btn')
    fused =cbam(fused)

    # Decoder with skip connections (U-Net style)
    # Upsample: S/32 → S/16 → S/8 → S/4 → S/2 → S
    x=Conv2DTranspose(128,2,strides=2,padding='same',name='up1')(fused)   # S/16
    x=BatchNormalization()(x); x=Activation('relu')(x)

    x=Conv2DTranspose(64,2,strides=2,padding='same',name='up2')(x)        # S/8
    f3r=Conv2D(64,1,padding='same')(f3)
    x=Concatenate()([x,f3r]); x=Conv2D(64,3,padding='same',activation='relu')(x)
    x=BatchNormalization()(x)

    x=Conv2DTranspose(32,2,strides=2,padding='same',name='up3')(x)        # S/4
    f2r=Conv2D(32,1,padding='same')(f2)
    x=Concatenate()([x,f2r]); x=Conv2D(32,3,padding='same',activation='relu')(x)
    x=BatchNormalization()(x)

    x=Conv2DTranspose(16,2,strides=2,padding='same',name='up4')(x)        # S/2
    f1r=Conv2D(16,1,padding='same')(f1)
    x=Concatenate()([x,f1r]); x=Conv2D(16,3,padding='same',activation='relu')(x)
    x=BatchNormalization()(x)

    x=Conv2DTranspose(8,2,strides=2,padding='same',name='up5')(x)         # S
    x=Conv2D(8,3,padding='same',activation='relu')(x)

    seg_out=Conv2D(1,1,activation='sigmoid',name='segmentation')(x)

    # Classification head — built on top of fused bottleneck
    gap=GlobalAveragePooling2D(name='gap')(fused)
    # Strong head: BN → Dense → BN → Dense → output
    h=Dense(512,name='clf1')(gap)
    h=BatchNormalization(name='bn_clf1')(h); h=Activation('relu')(h); h=Dropout(0.4)(h)
    h=Dense(256,name='clf2')(h)
    h=BatchNormalization(name='bn_clf2')(h); h=Activation('relu')(h); h=Dropout(0.3)(h)
    dis_out=Dense(ND,activation='softmax',name='disease_class')(h)

    h2=Dense(128,activation='relu',name='stg1')(gap)
    h2=Dropout(0.3)(h2)
    stg_out=Dense(ST,activation='softmax',name='stage_class')(h2)

    return Model(inp,[seg_out,dis_out,stg_out],name='QFCNN_v5')

# =============================================================================
#  NOVEL C4 — TEMPORAL PROGNOSIS LSTM
# =============================================================================
def build_prognosis(cfg):
    S,CH,T=cfg['img_size'],cfg['channels'],4
    inp=Input((T,S,S,CH))
    cnn=keras.Sequential([
        Conv2D(16,3,padding='same',activation='relu'),MaxPooling2D(4),
        Conv2D(32,3,padding='same',activation='relu'),MaxPooling2D(4),
        GlobalAveragePooling2D(),Dense(32,activation='relu'),
    ],name='fenc')
    feats=TimeDistributed(cnn)(inp)
    x=LSTM(64,return_sequences=True)(feats); x=LSTM(32)(x); x=Dropout(0.2)(x)
    sp=Dense(4,activation='softmax',name='stage_progression')(x)
    pp=Dense(1,activation='sigmoid',name='progression_probability')(x)
    ug=Dense(4,activation='softmax',name='urgency_score')(x)
    return Model(inp,[sp,pp,ug],name='ProgLSTM')

# =============================================================================
#  BASELINE MODELS — same MobileNetV2 backbone, single-phase training
# =============================================================================
def _baseline_head(f4, f3, f2, f1, ND, ST, S):
    """Shared decoder + heads for all baselines."""
    x=Conv2DTranspose(128,2,strides=2,padding='same')(f4)
    x=BatchNormalization()(x); x=Activation('relu')(x)
    x=Conv2DTranspose(64,2,strides=2,padding='same')(x)
    f3r=Conv2D(64,1,padding='same')(f3)
    x=Concatenate()([x,f3r]); x=Conv2D(64,3,padding='same',activation='relu')(x); x=BatchNormalization()(x)
    x=Conv2DTranspose(32,2,strides=2,padding='same')(x)
    f2r=Conv2D(32,1,padding='same')(f2)
    x=Concatenate()([x,f2r]); x=Conv2D(32,3,padding='same',activation='relu')(x); x=BatchNormalization()(x)
    x=Conv2DTranspose(16,2,strides=2,padding='same')(x)
    f1r=Conv2D(16,1,padding='same')(f1)
    x=Concatenate()([x,f1r]); x=Conv2D(16,3,padding='same',activation='relu')(x); x=BatchNormalization()(x)
    x=Conv2DTranspose(8,2,strides=2,padding='same')(x)
    x=Conv2D(8,3,padding='same',activation='relu')(x)
    seg=Conv2D(1,1,activation='sigmoid',name='segmentation')(x)
    gap=GlobalAveragePooling2D()(f4)
    gap=Conv2D(64,1,padding='same',activation='relu')(f4)
    gap=GlobalAveragePooling2D()(gap)
    h=Dense(256,activation='relu')(gap); h=Dropout(0.3)(h)
    dis=Dense(ND,activation='softmax',name='disease_class')(h)
    stg=Dense(ST,activation='softmax',name='stage_class')(
            Dense(64,activation='relu')(gap))
    return seg,dis,stg

def _build_with_backbone(name, cfg, extra_layers_fn=None):
    S,CH,ND,ST=cfg['img_size'],cfg['channels'],cfg['num_diseases'],cfg['stages']
    inp=Input((S,S,CH))
    backbone=MobileNetV2(input_shape=(S,S,CH),include_top=False,weights='imagenet')
    backbone.trainable=False
    feat_names=['block_1_expand_relu','block_3_expand_relu','block_6_expand_relu','out_relu']
    bb=Model(backbone.input,[backbone.get_layer(n).output for n in feat_names],name=f'bb_{name}')
    f1,f2,f3,f4=bb(inp)
    if extra_layers_fn: f4=extra_layers_fn(f4)
    seg,dis,stg=_baseline_head(f4,f3,f2,f1,ND,ST,S)
    return Model(inp,[seg,dis,stg],name=name)

def build_unet(cfg):
    return _build_with_backbone('UNet',cfg)

def build_resnet(cfg):
    def res_fn(f4):
        sc=Conv2D(64,1,padding='same')(f4)
        x=Conv2D(64,3,padding='same',activation='relu')(f4)
        x=Conv2D(64,3,padding='same')(x)
        x=Add()([x,sc]); return Activation('relu')(x)
    return _build_with_backbone('ResNet',cfg,res_fn)

def build_vgg(cfg):
    def vgg_fn(f4):
        x=Conv2D(64,3,padding='same',activation='relu')(f4)
        return Conv2D(64,3,padding='same',activation='relu')(x)
    return _build_with_backbone('VGG',cfg,vgg_fn)

def build_fcn(cfg):
    def fcn_fn(f4):
        return Conv2D(64,1,padding='same',activation='relu')(f4)
    return _build_with_backbone('FCN',cfg,fcn_fn)

# =============================================================================
#  STABLE DICE LOSS  — no log, no NaN
# =============================================================================
def dice_loss(y_true, y_pred):
    yf=ops.reshape(y_true,(-1,)); pf=ops.clip(ops.reshape(y_pred,(-1,)),0,1)
    return 1.0-(2.0*ops.sum(yf*pf)+1.0)/(ops.sum(yf)+ops.sum(pf)+1.0)

# =============================================================================
#  TWO-PHASE TRAINING FOR QF-CNN
#  Phase 1: Freeze backbone, train classification head only
#  Phase 2: Unfreeze backbone, train everything with lower LR
# =============================================================================
def train_qfcnn_twophase(model, Xtr, ytr, Xvl, yvl, cfg):
    seg_tr,dc_tr,sc_tr=ytr; seg_vl,dc_vl,sc_vl=yvl
    ls=cfg['label_smooth']
    cb_es=EarlyStopping(monitor='val_disease_class_accuracy',
                        patience=cfg['patience'],restore_best_weights=True,
                        mode='max',verbose=1)
    cb_lr=ReduceLROnPlateau(monitor='val_loss',patience=3,factor=0.5,min_lr=1e-6,verbose=0)

    # ── PHASE 1: classification only ──────────────────────────────────────
    print("\n  [QF-CNN Phase 1] Training classification head only ...")
    # Temporarily compile with ONLY classification losses
    model.compile(
        optimizer=Adam(cfg['lr_phase1'],clipnorm=1.0),
        loss={'segmentation'  : dice_loss,
              'disease_class' : keras.losses.CategoricalCrossentropy(label_smoothing=ls),
              'stage_class'   : keras.losses.CategoricalCrossentropy(label_smoothing=ls)},
        # Segmentation weight = 0 → only classification gradient flows
        loss_weights={'segmentation':0.0,'disease_class':1.0,'stage_class':0.1},
        metrics={'disease_class':['accuracy'],'stage_class':['accuracy']}
    )
    h1=model.fit(
        Xtr,{'segmentation':seg_tr,'disease_class':dc_tr,'stage_class':sc_tr},
        validation_data=(Xvl,{'segmentation':seg_vl,'disease_class':dc_vl,'stage_class':sc_vl}),
        epochs=cfg['epochs_phase1'],batch_size=cfg['batch_size'],
        callbacks=[cb_es,cb_lr],verbose=1
    )
    p1_acc=max(h1.history['val_disease_class_accuracy'])
    print(f"\n  Phase 1 complete — best val_acc={p1_acc:.4f}")

    # ── PHASE 2: Unfreeze backbone, full training ──────────────────────────
    print("\n  [QF-CNN Phase 2] Unfreezing backbone, full multi-task training ...")
    # Unfreeze the backbone layers inside the model
    for layer in model.layers:
        if hasattr(layer, 'layers'):      # it's a sub-model (backbone)
            for sub in layer.layers[-30:]:  # unfreeze last 30 layers only
                sub.trainable=True
        layer.trainable=True

    model.compile(
        optimizer=Adam(cfg['lr_phase2'],clipnorm=1.0),
        loss={'segmentation'  : dice_loss,
              'disease_class' : keras.losses.CategoricalCrossentropy(label_smoothing=ls),
              'stage_class'   : keras.losses.CategoricalCrossentropy(label_smoothing=ls)},
        # Now include seg loss — classification already learned
        loss_weights={'segmentation':0.5,'disease_class':1.0,'stage_class':0.2},
        metrics={'disease_class':['accuracy'],'stage_class':['accuracy']}
    )
    cb_es2=EarlyStopping(monitor='val_disease_class_accuracy',
                         patience=cfg['patience'],restore_best_weights=True,
                         mode='max',verbose=1)
    cb_lr2=ReduceLROnPlateau(monitor='val_loss',patience=3,factor=0.5,min_lr=1e-7,verbose=0)
    h2=model.fit(
        Xtr,{'segmentation':seg_tr,'disease_class':dc_tr,'stage_class':sc_tr},
        validation_data=(Xvl,{'segmentation':seg_vl,'disease_class':dc_vl,'stage_class':sc_vl}),
        epochs=cfg['epochs_phase2'],batch_size=cfg['batch_size'],
        callbacks=[cb_es2,cb_lr2],verbose=1
    )
    p2_acc=max(h2.history['val_disease_class_accuracy'])
    print(f"\n  Phase 2 complete — best val_acc={p2_acc:.4f}")

    # Merge histories
    merged={}
    for k in h1.history:
        merged[k]=h1.history[k]+h2.history[k]
    best=max(merged['val_disease_class_accuracy'])
    print(f"  ✓ QF-CNN FINAL best_val_acc={best:.4f} | elapsed {time.time()-t0:.0f}s")
    return merged

# =============================================================================
#  SINGLE-PHASE TRAINING FOR BASELINES
# =============================================================================
def train_baseline(model, Xtr, ytr, Xvl, yvl, cfg, name):
    seg_tr,dc_tr,sc_tr=ytr; seg_vl,dc_vl,sc_vl=yvl
    ls=cfg['label_smooth']
    model.compile(
        optimizer=Adam(cfg['lr_phase1'],clipnorm=1.0),
        loss={'segmentation'  : 'binary_crossentropy',
              'disease_class' : keras.losses.CategoricalCrossentropy(label_smoothing=ls),
              'stage_class'   : keras.losses.CategoricalCrossentropy(label_smoothing=ls)},
        loss_weights={'segmentation':0.5,'disease_class':1.0,'stage_class':0.2},
        metrics={'disease_class':['accuracy'],'stage_class':['accuracy']}
    )
    cbs=[EarlyStopping(monitor='val_disease_class_accuracy',patience=cfg['patience'],
                       restore_best_weights=True,mode='max',verbose=0),
         ReduceLROnPlateau(monitor='val_loss',patience=3,factor=0.5,min_lr=1e-6,verbose=0)]
    h=model.fit(
        Xtr,{'segmentation':seg_tr,'disease_class':dc_tr,'stage_class':sc_tr},
        validation_data=(Xvl,{'segmentation':seg_vl,'disease_class':dc_vl,'stage_class':sc_vl}),
        epochs=cfg['epochs_phase1']+cfg['epochs_phase2'],
        batch_size=cfg['batch_size'],callbacks=cbs,verbose=1
    )
    ep=len(h.history['loss']); va=max(h.history['val_disease_class_accuracy'])
    print(f"  ✓ {name} | {ep} epochs | best_val_acc={va:.4f} | elapsed {time.time()-t0:.0f}s")
    return h.history

# =============================================================================
#  EVALUATION
# =============================================================================
def evaluate(model, Xte, dc_oh, sc_oh, seg_gt):
    sp,dp,stp=model.predict(Xte,verbose=0,batch_size=32)
    dt=np.argmax(dc_oh,1); dpi=np.argmax(dp,1)
    st=np.argmax(sc_oh,1); stpi=np.argmax(stp,1)
    acc=accuracy_score(dt,dpi)
    f1m=f1_score(dt,dpi,average='macro',   zero_division=0)
    f1w=f1_score(dt,dpi,average='weighted',zero_division=0)
    try:    auc=roc_auc_score(dc_oh,dp,multi_class='ovr',average='macro')
    except: auc=0.0
    pb=(sp>0.5).astype(np.float32); gt=(seg_gt>0.5).astype(np.float32)
    fp=pb.flatten(); ft=gt.flatten()
    inter=(fp*ft).sum()
    dice=(2*inter+1e-6)/(fp.sum()+ft.sum()+1e-6)
    iou=(inter+1e-6)/(fp.sum()+ft.sum()-inter+1e-6)
    mse=((sp-seg_gt)**2).mean(); psnr=10*np.log10(1.0/(mse+1e-8)); ssim=float(np.clip(1-mse*2,0,1))
    return dict(accuracy=acc,f1_macro=f1m,f1_weighted=f1w,auc_roc=auc,
                dice=dice,iou=iou,psnr=psnr,ssim=ssim,
                stage_acc=accuracy_score(st,stpi),
                dc_pred=dp,dc_true=dc_oh,dc_pred_idx=dpi,dc_true_idx=dt,seg_pred=sp)

# =============================================================================
#  GRAD-CAM
# =============================================================================
def gradcam(model, img, cls=0):
    last_conv=None
    for l in reversed(model.layers):
        if isinstance(l,Conv2D): last_conv=l.name; break
    if last_conv is None: return np.zeros((4,4))
    try:
        gm=Model(model.inputs,[model.get_layer(last_conv).output,model.output[1]])
        xt=tf.cast(img[np.newaxis],tf.float32)
        with tf.GradientTape() as tape:
            cv,pred=gm(xt); loss=pred[:,cls]
        g=tape.gradient(loss,cv); p=tf.reduce_mean(g,axis=(0,1,2))
        hm=(cv[0]@p[...,tf.newaxis]).numpy().squeeze()
        hm=np.maximum(hm,0)
        if hm.max()>0: hm/=hm.max()
        return hm
    except: return np.zeros((4,4))

