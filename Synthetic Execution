def gaussian_blob(cx,cy,rx,ry,intensity=1.0,S=128):
    x=np.linspace(0,1,S); y=np.linspace(0,1,S)
    xx,yy=np.meshgrid(x,y)
    return intensity*np.exp(-((xx-cx)**2/(2*rx**2)+(yy-cy)**2/(2*ry**2)))

def preprocess(img):
    for c in range(img.shape[2]):
        img[:,:,c]=gaussian_filter(img[:,:,c],sigma=0.6)
    mn,mx=img.min(),img.max()
    return (img-mn)/(mx-mn+1e-8)

def gen_brain(sev):
    img=np.zeros((S,S,3))
    brain=gaussian_blob(0.5,0.5,0.3,0.35,0.6)
    img[:,:,0]=img[:,:,1]=img[:,:,2]=brain
    if sev>0:
        r=0.04+sev*0.06; cx=0.4+np.random.uniform(-0.1,0.1); cy=0.5+np.random.uniform(-0.1,0.1)
        t=gaussian_blob(cx,cy,r,r*0.8,0.9)
        img[:,:,0]+=t*0.8; img[:,:,2]+=t*0.3
    return np.clip(preprocess(img+np.random.normal(0,0.02,img.shape)),0,1)

def gen_alzh(sev):
    img=np.zeros((S,S,3))
    brain=gaussian_blob(0.5,0.5,0.32,0.38,0.7)
    a=max(0,1-sev*0.25)
    img[:,:,0]=brain*a; img[:,:,1]=brain*a*0.85; img[:,:,2]=brain*0.6
    vent=gaussian_blob(0.5,0.48,0.04+sev*0.03,0.07+sev*0.04,0.8)
    img[:,:,0]-=vent*0.6; img[:,:,1]-=vent*0.6
    return np.clip(preprocess(img+np.random.normal(0,0.02,img.shape)),0,1)

def gen_lung(sev):
    img=np.zeros((S,S,3))
    ll=gaussian_blob(0.35,0.5,0.2,0.3,0.5); lr=gaussian_blob(0.65,0.5,0.2,0.3,0.5)
    img[:,:,0]=img[:,:,1]=img[:,:,2]=(ll+lr)*0.6
    if sev>0:
        r=0.02+sev*0.04; cx=0.38+np.random.uniform(-0.05,0.05); cy=0.45+np.random.uniform(-0.05,0.05)
        n=gaussian_blob(cx,cy,r,r,1.0)
        img[:,:,0]+=n; img[:,:,1]+=n*0.5
    return np.clip(preprocess(img+np.random.normal(0,0.015,img.shape)),0,1)

def gen_breast(sev):
    img=np.zeros((S,S,3))
    tissue=gaussian_blob(0.5,0.5,0.38,0.42,0.55)
    img[:,:,0]=img[:,:,1]=img[:,:,2]=tissue
    if sev>0:
        r=0.03+sev*0.05
        mass=gaussian_blob(0.45,0.52,r,r*1.1,0.9)
        img[:,:,0]+=mass*0.9; img[:,:,1]+=mass*0.4; img[:,:,2]+=mass*0.2
    return np.clip(preprocess(img+np.random.normal(0,0.025,img.shape)),0,1)

