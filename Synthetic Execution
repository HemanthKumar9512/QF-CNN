# Training history simulation
def sim_history(epochs, final_acc, model_name):
    ep = np.arange(1, epochs+1)
    noise = lambda: np.random.normal(0, 0.01, epochs)
    acc   = final_acc * (1 - np.exp(-ep/8)) + noise()
    loss  = 1.5 * np.exp(-ep/7) + 0.05 + noise()
    v_acc = acc - np.random.uniform(0.02, 0.05) + noise()
    v_loss= loss + np.random.uniform(0.05, 0.15) + noise()
    seg   = 0.05 * np.exp(-ep/6) + 0.01 + np.abs(noise()*0.005)
    s_acc = (final_acc-0.01) * (1 - np.exp(-ep/10)) + noise()
    return dict(acc=np.clip(acc,0,1), loss=np.clip(loss,0,2),
                val_acc=np.clip(v_acc,0,1), val_loss=np.clip(v_loss,0,2),
                seg_mae=np.clip(seg,0,0.2), stage_acc=np.clip(s_acc,0,1))

