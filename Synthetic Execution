print("[Phase 4] Extracting Multi-Modal Deep Features...")

def extract_features(X, fuzzy_f):
    """Simulate CNN deep feature extraction"""
    feats = []
    for i, img in enumerate(X):
        ch_means  = img.mean(axis=(0,1))
        ch_stds   = img.std(axis=(0,1))
        # Simulated conv features — spatial statistics
        quad_means = np.array([img[:S//2,:S//2].mean(), img[:S//2,S//2:].mean(),
                                img[S//2:,:S//2].mean(), img[S//2:,S//2:].mean()])
        # Gradient energy (edge features)
        gx = np.diff(img[:,:,0], axis=1).std()
        gy = np.diff(img[:,:,0], axis=0).std()
        # Multi-modal fusion weights simulation (Novel C3)
        w1,w2,w3 = np.random.dirichlet([3,2,1])  # MRI, CT, PET weights
        fused_scalar = w1*ch_means[0] + w2*ch_means[1] + w3*ch_means[2]

        feat = np.concatenate([
            ch_means, ch_stds, quad_means,
            [gx, gy, fused_scalar, img.max(), img.min()],
            fuzzy_f[i]
        ])
        feats.append(feat)
    return np.array(feats, dtype=np.float32)

