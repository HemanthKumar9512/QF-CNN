def simulate_seg(img, dice_target):
    mask = img[:,:,0].copy()
    thr = np.percentile(mask, 80)
    pred = gaussian_filter((mask > thr).astype(float), sigma=3)
    noise = np.random.normal(0, 1-dice_target, pred.shape) * 0.12
    return np.clip(pred + noise, 0, 1)

