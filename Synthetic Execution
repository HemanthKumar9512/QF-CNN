print("\n[Phase 2] Applying Quantum-Inspired Feature Encoding (Novel C1)...")

def quantum_encode(X):
    """Simulated quantum rotation gate encoding"""
    theta = np.arctan(X * np.pi / 2.0)
    alpha = np.cos(theta)       # amplitude |0⟩
    beta  = np.sin(theta)       # amplitude |1⟩
    phi   = theta + 0.15        # phase shift (learned in TF version)
    psi_r = alpha * np.cos(phi)
    psi_i = beta  * np.sin(phi)
    quantum_feat = psi_r**2 + psi_i**2
    return np.clip(X * 1.05 + quantum_feat * 0.3, 0, 1)

