print("[Phase 3] Computing Fuzzy Membership Features (Novel C2)...")

def triangular_mf(x, a, b, c):
    return np.maximum(0, np.minimum((x-a)/(b-a+1e-8), (c-x)/(c-b+1e-8)))

def fuzzy_features(X):
    """Extract 5-set fuzzy membership features per image"""
    centers = np.linspace(0, 1, 5)
    w = 0.3
    feats = []
    for img in X:
        flat = img.flatten()
        mf_vals = [triangular_mf(flat, c-w, c, c+w).mean() for c in centers]
        feats.append(mf_vals)
    return np.array(feats, dtype=np.float32)

